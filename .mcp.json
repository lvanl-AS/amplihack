{
  "mcpServers": {
    "azure-devops": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@azure-devops/mcp",
        "${ADO_ORG}",
        "-a", "pat",
        "-d", "core", "work-items", "repositories", "pipelines", "work", "search", "wiki", "test-plans"
      ],
      "env": {
        "AZURE_DEVOPS_EXT_PAT": "${AZURE_DEVOPS_EXT_PAT}"
      }
    },
    "workiq": {
      "disabled": true,
      "command": "npx",
      "args": ["-y", "@microsoft/workiq", "mcp"]
    }
  }
}
